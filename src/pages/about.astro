---
import BaseLayout from '../layouts/BaseLayout.astro';

const interests = [
  "Imagination",
  "Better Living",
  "Creative Technology",
  "Art & Aesthetics",
  "Writing",
  "Data Art",
  "Digital Gardens",
  "Software Projects",
  "Religious Art",
  "AI & Creativity",
  "Worldbuilding",
  "Beautiful Tools",
  "Internet Projects",
  "Personal Transformation",
  "Taste & Design",
  "Spiritual Imagination",
  "The Future of Creativity",
];
---

<BaseLayout title="About" currentPage="about" description="Justin Culebro is a creative technologist building software, art, and imaginative tools for better living.">
  <h1 class="page-title">About</h1>
  <p class="page-subtitle">Imagination · Better Living · Art · Writing</p>

  <div class="info-grid">
    <span class="info-label">Role</span>
    <span class="info-value">Creative technologist building software, art, and imaginative tools for better living</span>
    <span class="info-label">Projects</span>
    <span class="info-value">Messiah AI</span>
    <span class="info-label">Location(s)</span>
    <span class="info-value">Salt Lake City, UT / Syracuse, NY / Tuxtla Gutiérrez, Mexico / Denver, CO</span>
    <span class="info-label">Background</span>
    <span class="info-value">I build at the intersection of art, software, writing, and better living. My work explores how imagination can shape more beautiful tools, more meaningful creative projects, and more thoughtful ways to live.</span>
  </div>

  <div style="margin-top: 32px;">
    <h2 class="section-heading">Interests</h2>
    <div class="section-divider"></div>
    <div class="badge-row">
      {interests.map((i) => <span class="badge badge-interest">{i}</span>)}
    </div>
  </div>
</BaseLayout>

<style>
  .badge-interest {
    color: var(--text-secondary);
  }
</style>
